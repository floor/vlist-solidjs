{
  "name": "vlist-solidjs",
  "version": "2.6.0",
  "description": "SolidJS primitives for vlist - lightweight virtual scrolling",
  "author": {
    "name": "Floor IO",
    "url": "https://floor.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floor/vlist-solidjs.git"
  },
  "keywords": [
    "vlist",
    "virtual-list",
    "solidjs",
    "solid",
    "primitives",
    "virtual-scrolling",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "vlist": "^2.6.0",
    "solid-js": ">=1.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "test": "bun test --conditions browser",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "vlist": "file:../vlist",
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/bun": "^1.0.0",
    "bun": "^1.0.0",
    "solid-js": "^1.9.3",
    "typescript": "^5.0.0"
  }
}
